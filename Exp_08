-- a) CREATE VIEW bank_head_office
-- Banks whose head office is at Ernakulam

CREATE VIEW bank_head_office AS
SELECT bankcode,bankname,headoffice,branches
FROM bank
WHERE headoffice='Ernakulam';


-- VIEW THE RESULT

SELECT * FROM bank_head_office;



-- b) CREATE VIEW bank_branch
-- Banks having branches at Kottayam

CREATE VIEW bank_branch AS
SELECT branchid,branchname,bankcode
FROM branch
WHERE branchname='Kottayam';


-- VIEW THE RESULT

SELECT * FROM bank_branch;